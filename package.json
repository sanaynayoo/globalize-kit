{
  "name": "@theo/globalize-kit",
  "version": "1.0.0",
  "description": "A lightweight TypeScript internationalization toolkit for React Native, Expo, and web applications.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
    "translation",
    "localization",
    "internationalization",
    "expo",
    "react-native",
    "typescript"
  ],
  "author": "theo",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}